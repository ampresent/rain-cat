__pycache__/

# 模型权重（大文件，从 R2/HF 下载）
models/

# 凭据文件（禁止入库）
.github-token
.hf-token
.s3cfg
.git-credentials-file
.git-credential

# 验证临时文件
_verify_preview.png

# 图片格式限制：只允许 webp，禁止其他格式
*.png
*.jpg
*.jpeg
*.bmp
*.gif
# 例外：cutout 逐帧 PNG（WebP 无法正确处理 alpha=0 的 RGB 清零）
!assets/sprites/cutout_*.png
.git-credential
